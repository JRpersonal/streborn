---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import Compatibility from '../../components/Compatibility.astro';
import Download from '../../components/Download.astro';
import Verify from '../../components/Verify.astro';
import Donate from '../../components/Donate.astro';
import FAQ from '../../components/FAQ.astro';

const lang = 'de';
const title = 'STR: Internet Radio fuer Bose SoundTouch ohne Cloud';
const description = 'Bose hat den Cloud Dienst eingestellt. STR (SoundTouch Reborn) laesst deine SoundTouch Lautsprecher autonom weiterlaufen. Internet Radio, Preset Tasten, alles ueber einen USB Stick. Open Source unter MIT.';
---

<Base title={title} description={description} lang={lang}>
  <Hero lang={lang} />
  <Features lang={lang} />
  <Compatibility lang={lang} />
  <Download lang={lang} />
  <Verify lang={lang} />
  <Donate lang={lang} />
  <FAQ lang={lang} />
</Base>

---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Diese URLs passt Jens nach Anmeldung der jeweiligen Plattform an.
const channels = [
  { key: 'github', href: 'https://github.com/sponsors/JRpersonal', accent: 'bg-pink-100 text-pink-700' },
  { key: 'bmc', href: 'https://www.buymeacoffee.com/jrpersonal', accent: 'bg-yellow-100 text-yellow-800' },
  { key: 'kofi', href: 'https://ko-fi.com/jrpersonal', accent: 'bg-red-100 text-red-700' },
  { key: 'liberapay', href: 'https://liberapay.com/JRpersonal/donate', accent: 'bg-amber-100 text-amber-800' },
  { key: 'paypal', href: 'https://paypal.me/JRpersonal', accent: 'bg-blue-100 text-blue-800' },
  { key: 'opencollective', href: 'https://opencollective.com/streborn', accent: 'bg-sky-100 text-sky-800' },
] as const;
---

<section id="donate" class="section">
  <div class="container-prose">
    <div class="max-w-prose">
      <h2 class="heading-2">{t('donate.heading')}</h2>
      <p class="mt-4 text-brand-700 leading-relaxed">{t('donate.subheading')}</p>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {channels.map((c) => (
        <a href={c.href} rel="noopener" class="card flex items-center gap-4">
          <span class={`shrink-0 w-10 h-10 rounded-lg flex items-center justify-center font-bold ${c.accent}`}>
            {t(`donate.${c.key}` as any).charAt(0)}
          </span>
          <span class="font-medium">{t(`donate.${c.key}` as any)}</span>
          <svg class="ml-auto text-brand-300" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17 17 7M7 7h10v10"/>
          </svg>
        </a>
      ))}
    </div>
    <p class="mt-10 text-sm text-brand-700 italic max-w-prose">{t('donate.transparency')}</p>
  </div>
</section>

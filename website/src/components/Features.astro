---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { key: 'f1', icon: 'radio' },
  { key: 'f2', icon: 'buttons' },
  { key: 'f3', icon: 'desktop' },
  { key: 'f4', icon: 'plug' },
  { key: 'f5', icon: 'lock' },
  { key: 'f6', icon: 'code' },
] as const;
---

<section id="features" class="section bg-white border-y border-brand-100">
  <div class="container-prose">
    <div class="max-w-prose">
      <h2 class="heading-2">{t('features.heading')}</h2>
      <p class="mt-4 text-brand-700 leading-relaxed">{t('features.subheading')}</p>
    </div>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map(({ key, icon }) => (
        <div class="card">
          <div class="w-10 h-10 rounded-lg bg-accent-500/10 flex items-center justify-center text-accent-600 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {icon === 'radio' && (<>
                <circle cx="12" cy="12" r="2"/>
                <path d="M16.24 7.76a6 6 0 0 1 0 8.49m-8.48-.01a6 6 0 0 1 0-8.49m11.31-2.82a10 10 0 0 1 0 14.14m-14.14 0a10 10 0 0 1 0-14.14"/>
              </>)}
              {icon === 'buttons' && (<>
                <circle cx="6" cy="6" r="2"/>
                <circle cx="12" cy="6" r="2"/>
                <circle cx="18" cy="6" r="2"/>
                <circle cx="6" cy="12" r="2"/>
                <circle cx="12" cy="12" r="2"/>
                <circle cx="18" cy="12" r="2"/>
              </>)}
              {icon === 'desktop' && (<>
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </>)}
              {icon === 'plug' && (<>
                <path d="M6 7v4a6 6 0 0 0 12 0V7"/>
                <path d="M9 3v4M15 3v4M12 17v5"/>
              </>)}
              {icon === 'lock' && (<>
                <rect x="3" y="11" width="18" height="11" rx="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </>)}
              {icon === 'code' && (<>
                <polyline points="16 18 22 12 16 6"/>
                <polyline points="8 6 2 12 8 18"/>
              </>)}
            </svg>
          </div>
          <h3 class="heading-3">{t(`features.${key}.title` as any)}</h3>
          <p class="mt-2 text-brand-700">{t(`features.${key}.body` as any)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

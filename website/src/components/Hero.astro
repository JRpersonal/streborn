---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section pt-12 sm:pt-16">
  <div class="container-prose grid lg:grid-cols-2 gap-12 items-center">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-100 text-brand-700 px-3 py-1 text-xs font-medium">
        <span class="w-2 h-2 rounded-full bg-accent-500"></span>
        {t('hero.badge')}
      </span>
      <p class="mt-4 text-accent-600 font-medium tracking-wide uppercase text-sm">{t('hero.tagline')}</p>
      <h1 class="heading-1 mt-3">{t('hero.headline')}</h1>
      <p class="mt-6 text-lg text-brand-700 leading-relaxed max-w-prose">{t('hero.subline')}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#download" class="btn-primary">{t('hero.cta_download')}</a>
        <a href="https://github.com/JRpersonal/streborn" rel="noopener" class="btn-secondary">{t('hero.cta_github')}</a>
      </div>
    </div>
    <div class="relative">
      <!-- Illustration: USB Stick steckt in Lautsprecher -->
      <svg viewBox="0 0 500 400" class="w-full h-auto" role="img" aria-label="USB stick inserted into a SoundTouch speaker">
        <defs>
          <linearGradient id="speaker" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#5f4e2f"/>
            <stop offset="100%" stop-color="#332916"/>
          </linearGradient>
        </defs>
        <rect x="60" y="80" width="380" height="240" rx="16" fill="url(#speaker)"/>
        <circle cx="180" cy="200" r="60" fill="#1a1a1a"/>
        <circle cx="180" cy="200" r="40" fill="#0a0a0a"/>
        <circle cx="180" cy="200" r="15" fill="#d65a31"/>
        <circle cx="320" cy="200" r="60" fill="#1a1a1a"/>
        <circle cx="320" cy="200" r="40" fill="#0a0a0a"/>
        <circle cx="320" cy="200" r="15" fill="#d65a31"/>
        <!-- Preset Tasten -->
        {[0,1,2,3,4,5].map((i) => (
          <circle cx={90 + i * 64} cy={110} r="6" fill="#f4f1ec" opacity="0.7"/>
        ))}
        <!-- USB Stick auf Rueckseite -->
        <rect x="430" y="155" width="50" height="22" rx="3" fill="#d65a31"/>
        <rect x="476" y="160" width="8" height="12" fill="#bf4a25"/>
        <text x="455" y="200" text-anchor="middle" font-size="12" fill="#f4f1ec" font-family="monospace">stick</text>
      </svg>
    </div>
  </div>
</section>

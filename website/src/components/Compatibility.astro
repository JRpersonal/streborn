---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const models = [
  { name: 'SoundTouch 10', status: 'tested' },
  { name: 'SoundTouch 20', status: 'planned' },
  { name: 'SoundTouch 30', status: 'planned' },
  { name: 'SoundTouch 300', status: 'planned' },
  { name: 'Wave SoundTouch IV', status: 'planned' },
  { name: 'SoundTouch Portable', status: 'in_progress' },
];

const statusLabel: Record<string, string> = {
  tested: t('compat.tested'),
  in_progress: t('compat.in_progress'),
  planned: t('compat.planned'),
};

const statusClass: Record<string, string> = {
  tested: 'bg-green-100 text-green-800',
  in_progress: 'bg-amber-100 text-amber-800',
  planned: 'bg-brand-100 text-brand-700',
};
---

<section class="section">
  <div class="container-prose">
    <div class="max-w-prose">
      <h2 class="heading-2">{t('compat.heading')}</h2>
      <p class="mt-4 text-brand-700">{t('compat.subheading')}</p>
    </div>
    <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {models.map((m) => (
        <div class="flex items-center justify-between rounded-lg border border-brand-100 bg-white px-5 py-4">
          <span class="font-medium">{m.name}</span>
          <span class={`text-xs px-2 py-1 rounded-full ${statusClass[m.status]}`}>{statusLabel[m.status]}</span>
        </div>
      ))}
    </div>
    <p class="mt-8 text-xs text-brand-700 italic">{t('compat.disclaimer')}</p>
  </div>
</section>

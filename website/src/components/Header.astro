---
import { useTranslations, localizedPath, languages, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const path = Astro.url.pathname;

// Sprachumschalter Ziel berechnen.
// Default Locale ist englisch und steht auf /. Deutsch liegt unter /de/.
function switchTo(target: Lang): string {
  // aktuellen Sprach Praefix entfernen
  const base = path.replace(/^\/de(\/|$)/, '/');
  if (target === 'en') {
    return base;
  }
  // Pfad ohne fuehrenden Slash anhaengen unter /de
  return `/de${base === '/' ? '/' : base}`;
}
---

<header class="sticky top-0 z-40 backdrop-blur bg-brand-50/85 border-b border-brand-100">
  <div class="container-prose flex items-center justify-between h-16">
    <a href={localizedPath(lang, '/')} class="flex items-center gap-2 font-semibold tracking-tight">
      <svg width="28" height="28" viewBox="0 0 28 28" aria-hidden="true">
        <rect x="2" y="6" width="24" height="16" rx="3" fill="#5f4e2f"/>
        <circle cx="14" cy="14" r="5" fill="#d65a31"/>
        <circle cx="14" cy="14" r="2" fill="#f4f1ec"/>
      </svg>
      <span class="text-lg font-bold tracking-tight">STR</span>
      <span class="hidden sm:inline text-xs text-brand-700 ml-1">SoundTouch Reborn</span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm">
      <a href="#features" class="hover:text-accent-500">{t('nav.features')}</a>
      <a href="#download" class="hover:text-accent-500">{t('nav.download')}</a>
      <a href="#donate" class="hover:text-accent-500">{t('nav.donate')}</a>
      <a href="#faq" class="hover:text-accent-500">{t('nav.faq')}</a>
      <a href="https://github.com/JRpersonal/streborn" rel="noopener" class="hover:text-accent-500">{t('nav.github')}</a>
    </nav>
    <div class="flex items-center gap-2 text-sm">
      {Object.entries(languages).map(([code, label]) => (
        <a
          href={switchTo(code as Lang)}
          class={`px-2 py-1 rounded ${code === lang ? 'bg-brand-100 text-brand-900' : 'text-brand-700 hover:text-accent-500'}`}
          hreflang={code}
          aria-current={code === lang ? 'true' : undefined}
        >
          {code.toUpperCase()}
        </a>
      ))}
    </div>
  </div>
</header>

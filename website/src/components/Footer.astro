---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

// Pfade je Sprache. Beide Sprachen haben unterschiedliche Slugs fuer
// rechtliche Seiten weil deutscher und englischer Begriff abweichen.
const imprintPath = lang === 'de' ? '/de/impressum/' : '/imprint/';
const privacyPath = lang === 'de' ? '/de/datenschutz/' : '/privacy/';
---

<footer class="bg-brand-900 text-brand-100">
  <div class="container-prose py-12 grid gap-8 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-2 font-semibold tracking-tight text-brand-50">
        <svg width="22" height="22" viewBox="0 0 28 28" aria-hidden="true">
          <rect x="2" y="6" width="24" height="16" rx="3" fill="#d65a31"/>
          <circle cx="14" cy="14" r="5" fill="#332916"/>
        </svg>
        STR
        <span class="text-xs font-normal text-brand-100/70 ml-1">SoundTouch Reborn</span>
      </div>
      <p class="mt-3 text-sm leading-relaxed">{t('footer.builtwith')}</p>
    </div>
    <nav class="text-sm">
      <h4 class="font-semibold text-brand-50 mb-3">{t('footer.about')}</h4>
      <ul class="space-y-2">
        <li><a href="https://github.com/JRpersonal/streborn" class="hover:text-white">{t('footer.github')}</a></li>
        <li><a href="https://github.com/JRpersonal/streborn#readme" class="hover:text-white">{t('footer.docs')}</a></li>
        <li><a href="#donate" class="hover:text-white">{t('nav.donate')}</a></li>
      </ul>
    </nav>
    <nav class="text-sm">
      <h4 class="font-semibold text-brand-50 mb-3">Legal</h4>
      <ul class="space-y-2">
        <li><a href={imprintPath} class="hover:text-white">{t('footer.imprint')}</a></li>
        <li><a href={privacyPath} class="hover:text-white">{t('footer.privacy')}</a></li>
      </ul>
    </nav>
  </div>
  <div class="border-t border-brand-700">
    <div class="container-prose py-4 text-xs flex flex-col md:flex-row gap-2 md:items-center justify-between">
      <span>(c) {year} STR (SoundTouch Reborn). MIT License.</span>
      <span class="text-brand-100/70">{t('footer.disclaimer')}</span>
    </div>
  </div>
</footer>

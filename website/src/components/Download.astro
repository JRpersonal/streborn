---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

// Download URLs zeigen auf das GitHub Release. Beim neuen Release Tag updaten.
const releaseBase = 'https://github.com/JRpersonal/streborn/releases/latest/download';
const platforms = [
  {
    titleKey: 'download.win.title',
    bodyKey: 'download.win.body',
    ctaKey: 'download.win.cta',
    file: 'STR-Setup-Windows.exe',
    size: 'ca. 18 MB',
    icon: 'windows',
  },
  {
    titleKey: 'download.mac.title',
    bodyKey: 'download.mac.body',
    ctaKey: 'download.mac.cta',
    file: 'STR-Setup-macOS.dmg',
    size: 'ca. 24 MB',
    icon: 'apple',
  },
] as const;
---

<section id="download" class="section bg-brand-900 text-brand-50">
  <div class="container-prose">
    <div class="max-w-prose">
      <h2 class="heading-2 text-brand-50">{t('download.heading')}</h2>
      <p class="mt-4 text-brand-100">{t('download.subheading')}</p>
    </div>
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {platforms.map((p) => (
        <div class="rounded-xl border border-brand-700 bg-brand-700/30 p-6">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-xl font-semibold text-brand-50">{t(p.titleKey as any)}</h3>
              <p class="mt-2 text-brand-100 text-sm">{t(p.bodyKey as any)}</p>
            </div>
            <div class="w-10 h-10 rounded-lg bg-brand-50/10 flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                {p.icon === 'windows' && (
                  <path d="M3 5.5 10.5 4.4v7.1H3V5.5zm0 13L10.5 19.6v-7.1H3v6zm8.5 1.2 9.5 1.3V12.5h-9.5v7.2zm0-8.7H21V2.5l-9.5 1.3v7.2z"/>
                )}
                {p.icon === 'apple' && (
                  <path d="M16.36 1.43c.1 1.43-.45 2.85-1.28 3.86-.85 1.04-2.22 1.83-3.59 1.74-.1-1.4.5-2.84 1.35-3.83.86-1.02 2.32-1.74 3.52-1.77zm4.13 17.34c-.6 1.32-1.31 2.62-2.49 2.65-1.13.03-1.5-.67-2.97-.67-1.47 0-1.88.65-2.97.7-1.18.04-2-1.4-2.61-2.7-1.27-2.66-2.24-7.52.95-10.8.84-.85 2.01-1.39 3.27-1.41 1.16-.02 2.26.78 2.97.78.7 0 2.05-.95 3.45-.81.58.02 2.23.23 3.3 1.74-.08.06-1.96 1.16-1.94 3.43.02 2.72 2.4 3.63 2.43 3.64-.03.07-.38 1.27-1.26 2.45z"/>
                )}
              </svg>
            </div>
          </div>
          <a href={`${releaseBase}/${p.file}`} class="mt-6 btn bg-accent-500 hover:bg-accent-600 text-white w-full">
            {t(p.ctaKey as any)}
          </a>
          <dl class="mt-4 grid grid-cols-2 gap-2 text-xs text-brand-100">
            <div>
              <dt class="opacity-70">{t('download.size')}</dt>
              <dd class="font-mono">{p.size}</dd>
            </div>
            <div>
              <dt class="opacity-70">{t('download.checksum')}</dt>
              <dd>
                <a href={`${releaseBase}/${p.file}.sha256`} class="underline decoration-dotted hover:text-white">.sha256</a>
              </dd>
            </div>
          </dl>
        </div>
      ))}
    </div>
    <p class="mt-8 text-sm text-brand-100">
      {t('download.source')}{' '}
      <a href="https://github.com/JRpersonal/streborn" class="underline hover:text-white">github.com/JRpersonal/streborn</a>
    </p>
  </div>
</section>

---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="verify" class="section bg-brand-100/40 border-y border-brand-100">
  <div class="container-prose">
    <div class="max-w-prose">
      <div class="inline-flex items-center gap-2 text-xs font-medium uppercase tracking-wider text-accent-600 mb-3">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 12l2 2 4-4"/>
          <path d="M12 22c5.5 0 10-4.5 10-10S17.5 2 12 2 2 6.5 2 12s4.5 10 10 10z"/>
        </svg>
        Supply Chain Security
      </div>
      <h2 class="heading-2">{t('verify.heading')}</h2>
      <p class="mt-4 text-brand-700 leading-relaxed">{t('verify.intro')}</p>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      <div class="card">
        <h3 class="heading-3">{t('verify.method1.title')}</h3>
        <p class="mt-2 text-brand-700">{t('verify.method1.body')}</p>
        <pre class="mt-4 overflow-x-auto rounded-lg bg-brand-900 text-brand-50 text-sm p-4"><code>{`# Windows PowerShell
Get-FileHash .\\STR-Setup-Windows.exe -Algorithm SHA256

# macOS oder Linux
shasum -a 256 STR-Setup-macOS.dmg`}</code></pre>
      </div>

      <div class="card">
        <h3 class="heading-3">{t('verify.method2.title')}</h3>
        <p class="mt-2 text-brand-700">{t('verify.method2.body')}</p>
        <pre class="mt-4 overflow-x-auto rounded-lg bg-brand-900 text-brand-50 text-sm p-4"><code>{`# Mit GitHub CLI installieren: https://cli.github.com
gh attestation verify \\
   STR-Setup-Windows.exe \\
   --owner JRpersonal`}</code></pre>
      </div>
    </div>

    <p class="mt-8 text-sm text-brand-700 max-w-prose">
      <span class="font-semibold">{t('verify.note')}</span>
    </p>
  </div>
</section>

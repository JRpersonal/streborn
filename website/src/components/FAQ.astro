---
import { useTranslations, type Lang } from '../i18n/ui';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = ['q1','q2','q3','q4','q5','q6','q7'] as const;
---

<section id="faq" class="section bg-white border-y border-brand-100">
  <div class="container-prose">
    <h2 class="heading-2">{t('faq.heading')}</h2>
    <div class="mt-10 grid gap-3 max-w-3xl">
      {items.map((q) => (
        <details class="group rounded-lg border border-brand-100 bg-white open:bg-brand-50 transition-colors">
          <summary class="cursor-pointer list-none px-5 py-4 flex items-center justify-between gap-4 font-medium">
            <span>{t(`faq.${q}.q` as any)}</span>
            <span class="text-brand-700 group-open:rotate-180 transition-transform" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </summary>
          <div class="px-5 pb-5 text-brand-700 leading-relaxed">
            {t(`faq.${q}.a` as any)}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

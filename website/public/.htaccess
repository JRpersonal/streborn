# STR Webseite - Apache Konfiguration
# Wird mit Astro Build nach dist/.htaccess kopiert und per FTP hochgeladen.
# Funktioniert auf den meisten Shared Hosting Anbietern (1und1, IONOS, Strato,
# Hetzner, Hostpoint, all-inkl, etc).

# ===================================================================
# 1. HTTPS erzwingen
# ===================================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # HTTP zu HTTPS umleiten (nur wenn das Cert schon installiert ist)
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # www auf root umleiten (oder umgekehrt, je nach Geschmack hier root)
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]
</IfModule>

# ===================================================================
# 2. Sicherheits Header
# ===================================================================
<IfModule mod_headers.c>
    # HTTPS dauerhaft erzwingen
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Anti Clickjacking
    Header always set X-Frame-Options "DENY"

    # MIME Sniffing aus
    Header always set X-Content-Type-Options "nosniff"

    # Referrer Schutz
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Sensible Browser Features aus
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"

    # Cross Origin Policy
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-site"

    # Content Security Policy
    # Wenn du GoatCounter aktivierst: gc.zgo.at bleibt drin.
    # Wenn nicht, kannst du gc.zgo.at und *.goatcounter.com aus der Liste streichen.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://gc.zgo.at; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://*.goatcounter.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"

    # Cache fuer immutable Assets
    <FilesMatch "\.(css|js|svg|png|jpg|jpeg|gif|webp|woff|woff2|ttf|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML nicht aggressiv cachen
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
</IfModule>

# ===================================================================
# 3. GZIP Kompression (falls mod_deflate aktiv)
# ===================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
</IfModule>

# Manche Hoster nutzen brotli statt deflate
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript image/svg+xml application/json text/xml text/plain
</IfModule>

# ===================================================================
# 4. Cache Expires (alternative Methode wenn mod_headers nicht da)
# ===================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ===================================================================
# 5. Pretty URLs ohne trailing slash
# ===================================================================
# Astro produziert /impressum/index.html, Browser besucht /impressum
<IfModule mod_rewrite.c>
    # Wenn /xyz aufgerufen wird und /xyz/index.html existiert -> intern leiten
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
    RewriteRule ^(.+?)/?$ $1/index.html [L]
</IfModule>

# ===================================================================
# 6. 404 Fallback
# ===================================================================
ErrorDocument 404 /404.html

# ===================================================================
# 7. Schutz vor sensiblen Dateien
# ===================================================================
<FilesMatch "^\.(env|git|htaccess|htpasswd)">
    Require all denied
</FilesMatch>

<FilesMatch "\.(md|yaml|yml|toml|log|sh|sql|bak|swp)$">
    Require all denied
</FilesMatch>

# ===================================================================
# 8. Default Charset
# ===================================================================
AddDefaultCharset UTF-8

# ===================================================================
# 9. PHP Sicherheit (falls aktiv)
# ===================================================================
<IfModule mod_php.c>
    php_flag expose_php Off
</IfModule>
<IfModule mod_php7.c>
    php_flag expose_php Off
</IfModule>
<IfModule mod_php8.c>
    php_flag expose_php Off
</IfModule>

# ===================================================================
# 10. Directory Listing aus
# ===================================================================
Options -Indexes -MultiViews

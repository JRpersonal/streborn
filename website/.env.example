# Beispiel Konfiguration. Datei nach `.env` kopieren und Werte eintragen.

# Pflicht: Basis URL der Live Seite. Wird fuer Sitemap, Canonical Tags und Open Graph genutzt.
PUBLIC_SITE_URL=https://streborn.de

# Optional: GoatCounter Subdomain ohne .goatcounter.com.
# Wenn leer wird kein Analytics geladen.
PUBLIC_GOATCOUNTER_CODE=

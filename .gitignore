# Build Output
/bin/
/dist/
*.exe
*.dmg
*.tar.gz
*.zip

# Wails App Build Output
/desktop-app/build/
/desktop-app/frontend/dist/
/desktop-app/frontend/node_modules/
/desktop-app/desktop-app/
/desktop-app/agentbin/streborn-*
/desktop-app/agentbin/*.bin
/sticksetup/embedded/

# Empty stubs that must remain tracked so go:embed succeeds on a fresh
# clone. CI overwrites them with the real binaries during release.
!/desktop-app/agentbin/streborn-armv7l
!/sticksetup/embedded/
!/sticksetup/embedded/winformat.exe
# Same idea for desktop-app/main.go's //go:embed all:frontend/dist —
# track only the stub, ignore everything wails/vite drops in there.
!/desktop-app/frontend/dist/
/desktop-app/frontend/dist/*
!/desktop-app/frontend/dist/.gitkeep

# Astro Webseite Build
/website/dist/
/website/node_modules/
/website/.astro/

# Node
node_modules/

# Env
.env
.env.local

# Editor
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Go Build
/agent.exe
*.test
*.out

# Tmp
*.tmp
*.bak
.cache/

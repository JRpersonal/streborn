# Force LF line endings for files that ship to the speaker or any
# Linux host. The speaker runs BusyBox sh, which fails to execute
# any shell script with CRLF endings — the `\r` ends up in the
# shebang and the kernel cannot find an interpreter named
# `/bin/sh\r`. This produced a "No such file or directory" error
# on a file that visibly exists, which is one of the meaner
# debugging traps in this codebase. Pin everything Linux-touched
# to LF here so this never reoccurs regardless of a contributor's
# core.autocrlf setting.

# Shell scripts and the on-stick rc.local must be LF.
*.sh           text eol=lf
usb-stick/rc.local text eol=lf

# Go source files. Some build tools choke on CRLF; rg/grep are
# noisier with CRLF; keep LF everywhere.
*.go           text eol=lf

# Patch files must stay LF: `git apply` in the go-librespot build fails on
# CRLF patches against LF upstream source.
*.patch        text eol=lf

# Configuration and data files consumed by the agent or Bose firmware.
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.conf         text eol=lf

# Documentation can be either, but enforcing LF avoids spurious
# diffs and keeps web rendering consistent.
*.md           text eol=lf

# Cross-platform helpers: PowerShell + .cmd stay CRLF (native to
# Windows shells); .ps1 tolerates LF but tooling defaults expect
# CRLF, so leave them platform-native.
*.ps1          text eol=crlf
*.cmd          text eol=crlf
*.bat          text eol=crlf

# Binaries — be explicit, never touch them.
*.exe          binary
*.dll          binary
*.png          binary
*.jpg          binary
*.ico          binary
*.dmg          binary

# The embedded ARM agent stub and winformat helper are tracked
# binaries even when they happen to be empty stubs on a clean
# checkout. Treating them as binary keeps git from line-ending
# transforming a real ELF the moment CI fills it in.
desktop-app/agentbin/streborn-armv7l binary
sticksetup/embedded/winformat.exe    binary
